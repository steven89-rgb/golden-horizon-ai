# =============================================================================
# Golden Horizon AI Backend - Environment Configuration
# Copy to `.env` and fill in real values:   cp .env.example .env
# NEVER commit the real .env. Only .env.example is tracked.
# =============================================================================

# --- Application ---------------------------------------------------------------
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
TZ=UTC

# --- FastAPI -------------------------------------------------------------------
BACKEND_PORT=8000

# --- PostgreSQL + pgvector (NOT published to the host) -------------------------
POSTGRES_USER=golden_horizon
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=golden_horizon
# For host tooling (e.g. Alembic in Phase 2). Containers build their own URL.
DATABASE_URL=postgresql+asyncpg://golden_horizon:change_me_to_a_strong_password@localhost:5432/golden_horizon

# --- N8N -----------------------------------------------------------------------
N8N_PORT=5678
N8N_DB_NAME=n8n
# Generate with: openssl rand -hex 24
N8N_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_24
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_to_a_strong_password

# --- AI Providers (used by OpenClaw / knowledge base in later phases) ----------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- WooCommerce (connector, Phase 3) ------------------------------------------
WC_URL=https://goldenhorizonresearch.com
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
